model Product {
  id            String   @id @default(uuid())
  name          String
  description   String
  stockQuantity Int
  price         Float
  imageUrl      String?
  weight        Float
  width         Float
  height        Float
  length        Float
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  orderItems OrderItem[]
  cartItems  CartItem[]
}
